{
  "datasets": [
    {
      "name": "silver_session_summary",
      "displayName": "Session Summary",
      "config": {
        "source": "tanner_fevm_catalog.claude_silver.session_summary",
        "measures": [
          {
            "name": "session_count",
            "expr": "COUNT(DISTINCT session_id)",
            "displayName": "Total Sessions"
          },
          {
            "name": "total_input_tokens",
            "expr": "SUM(total_input_tokens)",
            "displayName": "Total Input Tokens",
            "format": {
              "type": "number",
              "abbreviation": "compact"
            }
          },
          {
            "name": "total_output_tokens",
            "expr": "SUM(total_output_tokens)",
            "displayName": "Total Output Tokens",
            "format": {
              "type": "number",
              "abbreviation": "compact"
            }
          },
          {
            "name": "total_cache_read",
            "expr": "SUM(total_cache_read)",
            "displayName": "Total Cache Read",
            "format": {
              "type": "number",
              "abbreviation": "compact"
            }
          },
          {
            "name": "avg_cache_hit_rate",
            "expr": "AVG(cache_hit_rate)",
            "displayName": "Avg Cache Hit Rate",
            "format": {
              "type": "percentage",
              "decimalPlaces": {
                "type": "exact",
                "places": 1.0
              }
            }
          },
          {
            "name": "avg_tool_success_rate",
            "expr": "AVG(tool_success_rate)",
            "displayName": "Avg Tool Success Rate",
            "format": {
              "type": "percentage",
              "decimalPlaces": {
                "type": "exact",
                "places": 1.0
              }
            }
          },
          {
            "name": "total_cost",
            "expr": "SUM(total_cost_usd)",
            "displayName": "Total Cost USD",
            "format": {
              "type": "currency",
              "currencyCode": "USD",
              "decimalPlaces": {
                "type": "exact",
                "places": 2.0
              }
            }
          },
          {
            "name": "avg_session_duration_min",
            "expr": "AVG(session_duration_s) / 60.0",
            "displayName": "Avg Session Duration (min)",
            "format": {
              "type": "number",
              "decimalPlaces": {
                "type": "exact",
                "places": 1.0
              }
            }
          },
          {
            "name": "avg_tools_per_interaction",
            "expr": "AVG(tools_per_interaction)",
            "displayName": "Avg Tools per Interaction",
            "format": {
              "type": "number",
              "decimalPlaces": {
                "type": "exact",
                "places": 1.0
              }
            }
          },
          {
            "name": "total_tool_calls",
            "expr": "SUM(num_tool_calls)",
            "displayName": "Total Tool Calls"
          },
          {
            "name": "total_llm_requests",
            "expr": "SUM(num_llm_requests)",
            "displayName": "Total LLM Requests"
          }
        ],
        "filter": "num_interactions >= 2",
        "version": 1.1,
        "dimensions": [
          {
            "name": "session_id",
            "expr": "session_id"
          },
          {
            "name": "session_start",
            "expr": "session_start",
            "displayName": "Session Start",
            "format": {
              "type": "date_time",
              "dateFormat": "locale_short_month",
              "timeFormat": "locale_hour_minute"
            }
          },
          {
            "name": "session_date",
            "expr": "DATE_TRUNC('DAY', session_start)",
            "displayName": "Session Date",
            "format": {
              "type": "date",
              "dateFormat": "year_month_day"
            }
          },
          {
            "name": "os_type",
            "expr": "os_type",
            "displayName": "OS Type"
          },
          {
            "name": "terminal_type",
            "expr": "terminal_type",
            "displayName": "Terminal Type"
          }
        ]
      }
    },
    {
      "name": "gold_session_scores",
      "displayName": "Session Scores",
      "config": {
        "source": "tanner_fevm_catalog.claude_gold.session_scores",
        "measures": [
          {
            "name": "session_count",
            "expr": "COUNT(DISTINCT session_id)",
            "displayName": "Total Sessions",
            "comment": "Count of distinct sessions"
          },
          {
            "displayName": "Avg Composite Score",
            "format": {
              "type": "number",
              "decimalPlaces": {
                "type": "exact",
                "places": 1.0
              }
            },
            "name": "avg_composite",
            "expr": "AVG(composite_score)",
            "comment": "Average weighted composite score"
          },
          {
            "name": "avg_efficiency",
            "expr": "AVG(efficiency_score)",
            "displayName": "Avg Efficiency",
            "format": {
              "type": "number",
              "decimalPlaces": {
                "type": "exact",
                "places": 1.0
              }
            }
          },
          {
            "name": "avg_productivity",
            "expr": "AVG(productivity_score)",
            "displayName": "Avg Productivity",
            "format": {
              "type": "number",
              "decimalPlaces": {
                "type": "exact",
                "places": 1.0
              }
            }
          },
          {
            "name": "avg_quality",
            "expr": "AVG(quality_score)",
            "displayName": "Avg Quality",
            "format": {
              "type": "number",
              "decimalPlaces": {
                "type": "exact",
                "places": 1.0
              }
            }
          },
          {
            "name": "avg_autonomy",
            "expr": "AVG(autonomy_score)",
            "displayName": "Avg Autonomy",
            "format": {
              "type": "number",
              "decimalPlaces": {
                "type": "exact",
                "places": 1.0
              }
            }
          },
          {
            "name": "avg_engagement",
            "expr": "AVG(engagement_score)",
            "displayName": "Avg Engagement",
            "format": {
              "type": "number",
              "decimalPlaces": {
                "type": "exact",
                "places": 1.0
              }
            }
          },
          {
            "name": "avg_llm_task_clarity",
            "expr": "AVG(llm_task_clarity)",
            "displayName": "Avg Task Clarity",
            "format": {
              "type": "number",
              "decimalPlaces": {
                "type": "exact",
                "places": 1.0
              }
            }
          },
          {
            "name": "avg_llm_agent_effectiveness",
            "expr": "AVG(llm_agent_effectiveness)",
            "displayName": "Avg Agent Effectiveness",
            "format": {
              "type": "number",
              "decimalPlaces": {
                "type": "exact",
                "places": 1.0
              }
            }
          },
          {
            "name": "avg_llm_tool_strategy",
            "expr": "AVG(llm_tool_strategy)",
            "displayName": "Avg Tool Strategy",
            "format": {
              "type": "number",
              "decimalPlaces": {
                "type": "exact",
                "places": 1.0
              }
            }
          },
          {
            "name": "avg_llm_error_handling",
            "expr": "AVG(llm_error_handling)",
            "displayName": "Avg Error Handling",
            "format": {
              "type": "number",
              "decimalPlaces": {
                "type": "exact",
                "places": 1.0
              }
            }
          },
          {
            "name": "avg_llm_cost_efficiency",
            "expr": "AVG(llm_cost_efficiency)",
            "displayName": "Avg Cost Efficiency",
            "format": {
              "type": "number",
              "decimalPlaces": {
                "type": "exact",
                "places": 1.0
              }
            }
          },
          {
            "name": "avg_llm_overall",
            "expr": "AVG(llm_overall_score)",
            "displayName": "Avg LLM Overall",
            "format": {
              "type": "number",
              "decimalPlaces": {
                "type": "exact",
                "places": 1.0
              }
            }
          },
          {
            "displayName": "Total Cost USD",
            "format": {
              "type": "currency",
              "currencyCode": "USD",
              "decimalPlaces": {
                "type": "exact",
                "places": 2.0
              }
            },
            "name": "total_cost",
            "expr": "SUM(total_cost_usd)",
            "comment": "Sum of session costs"
          },
          {
            "name": "avg_interactions",
            "expr": "AVG(num_interactions)",
            "displayName": "Avg Interactions",
            "format": {
              "type": "number",
              "decimalPlaces": {
                "type": "exact",
                "places": 1.0
              }
            }
          }
        ],
        "filter": "num_interactions >= 2",
        "version": 1.1,
        "dimensions": [
          {
            "name": "session_id",
            "expr": "session_id",
            "comment": "Unique session identifier"
          },
          {
            "displayName": "Session Start",
            "format": {
              "type": "date_time",
              "dateFormat": "locale_short_month",
              "timeFormat": "locale_hour_minute"
            },
            "name": "session_start",
            "expr": "session_start",
            "comment": "When the session began"
          },
          {
            "displayName": "Session Date",
            "format": {
              "type": "date",
              "dateFormat": "year_month_day"
            },
            "name": "session_date",
            "expr": "DATE_TRUNC('DAY', session_start)",
            "comment": "Date of session start"
          },
          {
            "name": "num_interactions",
            "expr": "num_interactions",
            "displayName": "Interactions",
            "comment": "Number of user interactions in the session"
          },
          {
            "name": "llm_summary",
            "expr": "llm_summary",
            "displayName": "LLM Summary",
            "comment": "LLM-generated session summary"
          },
          {
            "name": "llm_recommendations",
            "expr": "llm_recommendations",
            "displayName": "LLM Recommendations",
            "comment": "LLM-generated improvement recommendations"
          }
        ]
      }
    }
  ],
